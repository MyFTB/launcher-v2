{
  "name": "myftb-launcher",
  "version": "2.1.0-experimental.1",
  "description": "MyFTB Minecraft Modpack Launcher",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "type-check": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p src/renderer/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@fontsource-variable/outfit": "^5.2.8",
    "@xhayper/discord-rpc": "^1.3.1",
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "de.myftb.launcher",
    "productName": "MyFTB Launcher",
    "copyright": "Copyright © MyFTB",
    "icon": "resources/icon",
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "protocols": [
      {
        "name": "MyFTB Launcher",
        "schemes": [
          "myftb"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png",
      "category": "Game"
    },
    "publish": {
      "provider": "github",
      "owner": "MyFTB",
      "repo": "launcher-v2"
    }
  },
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "MyFTB",
    "email": "info@myftb.de",
    "url": "https://myftb.de"
  }
}
