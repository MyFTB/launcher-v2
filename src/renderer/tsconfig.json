{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src/**/*", "../../src/shared/**/*"],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@renderer/*": ["./src/*"],
      "@shared/*": ["../../src/shared/*"]
    }
  }
}
